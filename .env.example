VIDEO_GROK_API_KEY=
VIDEO_GROK_BASE_URL=

# --- Web Search ---------------------------------------------------------------
# Note: Grok (xAI) web search is available via chat completions + search tools,
# not as a standalone search API. Use Grok LLM provider with search_parameters
# in chat requests. See: https://docs.x.ai/docs/guides/tools/search-tools

TAVILY_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- Misc ---------------------------------------------------------------------

# Optional server-side default model for API routes like /api/generate-classroom
# Example: anthropic:claude-3-5-haiku-20241022 or google:gemini-3-flash-preview
# MiniMax example: minimax:MiniMax-M2.7-highspeed
DEFAULT_MODEL=

# LOG_LEVEL=info
# LOG_FORMAT=pretty
# LLM_THINKING_DISABLED=false

# --- Local/Self-hosted Deployment ---------------------------------------------
# Set to "true" to allow private/local network URLs (e.g. localhost, 192.168.x.x).
# Required for self-hosted models like Ollama. Do NOT enable on public deployments.
# ALLOW_LOCAL_NETWORKS=true

# --- Access Control -----------------------------------------------------------
# Set a password to restrict site access. When set, users must enter this code
# before using the app. Leave empty or remove to disable access control.
# ACCESS_CODE=your-secret-code

# --- Storage ------------------------------------------------------------------
# Root directory for server-persisted classrooms, generated media, TTS audio,
# and generation-job state. Defaults to <cwd>/data (i.e. /app/data in the
# shipped Docker image). Set this to any writable absolute path to move storage
# elsewhere, e.g. an EFS/NFS bind mount.
#
# Boot-time behaviour:
#   - The process creates <DATA_DIR>/classrooms and <DATA_DIR>/classroom-jobs
#     at module load (recursive mkdir). A protected system path (/ , /etc ,
#     /usr , /bin , /proc , /sys , /dev , /root , /var) is rejected at startup.
#   - If the directory is not writable by the container user (uid 1001 in the
#     stock Dockerfile), startup fails with a clear error instead of a later 500.
#
# If you switch from the default Docker named volume to a host bind mount, the
# host directory MUST be writable by uid 1001. On first setup run:
#   sudo chown -R 1001:1001 <host-path>
# or (if you can't chown, e.g. shared EFS):
#   sudo chmod -R 0775 <host-path>
# DATA_DIR=/app/data

# --- OpenTelemetry / Distributed tracing --------------------------------------
# When OTEL_EXPORTER_OTLP_ENDPOINT is set, all server-side LLM calls and TTS
# provider attempts emit OpenTelemetry spans. Unset = zero-cost no-op.
# Bring up the "tempo" profile in docker-compose to run a local Tempo collector
# at http://tempo:4318 and query traces via the Grafana sidecar.
# OTEL_SERVICE_NAME=openmaic
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Rate Limiting ------------------------------------------------------------
# In-memory per-identifier rate limits on credit-burning routes.
# Defaults (requests / minute unless stated): chat=20, tts=60, generate=3/5min,
# verify=30, transcription=20, web_search=20, media=20.
# Override per bucket via RATE_LIMIT_<BUCKET>_PER_MINUTE; set RATE_LIMIT_DISABLED=1
# to bypass entirely (useful for load tests or single-user dev).
# RATE_LIMIT_DISABLED=0
# RATE_LIMIT_CHAT_PER_MINUTE=20
# RATE_LIMIT_TTS_PER_MINUTE=60
# RATE_LIMIT_GENERATE_PER_MINUTE=5
# RATE_LIMIT_VERIFY_PER_MINUTE=30
# RATE_LIMIT_TRANSCRIPTION_PER_MINUTE=20
# RATE_LIMIT_WEB_SEARCH_PER_MINUTE=20
# RATE_LIMIT_MEDIA_PER_MINUTE=20
