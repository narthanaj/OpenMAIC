{
  "name": "@openmaic/exporter",
  "version": "0.1.0",
  "private": true,
  "description": "Content export sidecar for OpenMAIC classrooms — SCORM 1.2 first, plugin architecture for future formats",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/exporters/scorm1_2/schema','dist/exporters/scorm1_2/schema',{recursive:true})\"",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/under-pressure": "^9.0.3",
    "better-sqlite3": "^11.5.0",
    "fastify": "^5.1.0",
    "jszip": "^3.10.1",
    "prom-client": "^15.1.3",
    "undici": "^7.2.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
